@model PRN232_Project_MVC.Models.FriendListViewModel
@{
    var friendListJson = System.Text.Json.JsonSerializer.Serialize(Model.FriendLists);
    var friendInvitationJson = System.Text.Json.JsonSerializer.Serialize(Model.FriendInvitations);
    var messagesJson = System.Text.Json.JsonSerializer.Serialize(Model.Messages);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Danh Sách Bạn Bè - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PRN232_Project_MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/friendlist.css"/>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>
                <span class="header-icon">🤝</span>
                Quản Lý Danh Sách Bạn Bè
            </h1>
            <nav class="nav-menu">
                <a href="/Admin/Users" class="nav-btn">👥 Người Dùng</a>
                <a href="/Admin/Friendlist" class="nav-btn active">🤝 Bạn Bè</a>
                <a href="/Admin/Accusations" class="nav-btn">⚠️ Tố Cáo</a>
                <a href="/Admin/Logs" class="nav-btn">📊 Nhật Ký</a>
            </nav>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Tổng Kết Nối Bạn Bè</h3>
                <div class="stat-value">@(Model.FriendLists.Count() + Model.FriendInvitations.Count())</div>
                <div class="stat-change positive">
                    ↑ +18.3% so với tháng trước
                </div>
            </div>
            <div class="stat-card">
                <h3>Đã Chấp Nhận</h3>
                <div class="stat-value">@Model.FriendLists.Count()</div>
                <div class="stat-change positive">
                    ↑ +15.7% so với tháng trước
                </div>
            </div>
            <div class="stat-card">
                <h3>Đang Chờ</h3>
                <div class="stat-value">@Model.FriendInvitations.Count()</div>
                <div class="stat-change negative">
                    ↓ -2.8% so với tháng trước
                </div>
            </div>
            <div class="stat-card">
                <h3>Đã Chặn</h3>
                <div class="stat-value">@Model.BlockLists.Count()</div>
                <div class="stat-change positive">
                    ↑ +7.2% so với tháng trước
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Danh Sách Kết Nối Bạn Bè</h2>
            </div>

            <div class="search-filter-bar">
                <div class="search-box">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Tìm kiếm theo tên người dùng...">
                </div>
                <select class="filter-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="accepted">Đã chấp nhận</option>
                    <option value="pending">Đang chờ</option>
                    <option value="blocked">Đã chặn</option>
                </select>
                <select class="filter-select">
                    <option value="">Sắp xếp theo</option>
                    <option value="newest">Mới nhất</option>
                    <option value="oldest">Cũ nhất</option>
                </select>
                <button id="excelBtn" class="btn-primary">
                    📊 Xuất Báo Cáo
                </button>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Người Dùng 1</th>
                            <th></th>
                            <th>Người Dùng 2</th>
                            <th>Trạng Thái</th>
                            <th>Ngày Kết Nối</th>
                            <th>Số Tin Nhắn</th>
                            <th>Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model.FriendLists)
                        {
                            <tr data-user1="@item.UserId1" data-user2="@item.UserId2" data-status="accepted">
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">NT</div>
                                        <div class="user-info">
                                            <h4>@item.UserId1Navigation.Username</h4>
                                            <p>@item.UserId1Navigation.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="connection-arrow">⟷</div>
                                </td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">LA</div>
                                        <div class="user-info">
                                            <h4>@item.UserId2Navigation.Username</h4>
                                            <p>@item.UserId2Navigation.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge accepted">ACCEPTED</span></td>
                                <td>@item.CreatedAt</td>
                                <td>@Model.Messages.Where(m => (m.SenderId == item.UserId1 && m.ReceiverId == item.UserId2) || (m.SenderId == item.UserId2 && m.ReceiverId == item.UserId1)).Count()</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action btn-view btn btn-sm btn-outline-primary">Chi tiết</button>
                                        @* <button class="btn-action btn-block btn btn-sm btn-outline-warning">Chặn</button> *@
                                        <button class="btn-action btn-remove btn btn-sm btn-outline-danger">Xóa</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model.FriendInvitations)
                        {
                            <tr data-user1="@item.SenderId" data-user2="@item.ReceiverId" data-status="pending">
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">NT</div>
                                        <div class="user-info">
                                            <h4>@item.Sender.Username</h4>
                                            <p>@item.Sender.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="connection-arrow">⟷</div>
                                </td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">LA</div>
                                        <div class="user-info">
                                            <h4>@item.Receiver.Username</h4>
                                            <p>@item.Receiver.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge pending">PENDING</span></td>
                                <td>@item.SentAt</td>
                                <td>0</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action btn-view btn btn-sm btn-outline-primary">Chi tiết</button>
                                        @* <button class="btn-action btn-block btn btn-sm btn-outline-warning">Chặn</button> *@
                                        <button class="btn-action btn-remove btn btn-sm btn-outline-danger">Xóa</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @* @foreach (var item in Model.BlockLists)
                        {
                            <tr data-user1="@item.BlockerId" data-user2="@item.BlockedId" data-status="blocked">
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">NT</div>
                                        <div class="user-info">
                                            <h4>@item.Blocker.Username</h4>
                                            <p>@item.Blocker.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="connection-arrow">⟷</div>
                                </td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">LA</div>
                                        <div class="user-info">
                                            <h4>@item.Blocked.Username</h4>
                                            <p>@item.Blocked.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge blocked">BLOCKED</span></td>
                                <td>@item.ExpiresAt</td>
                                <td>@Model.Messages.Where(m => (m.SenderId == item.BlockerId && m.ReceiverId == item.BlockedId) || (m.SenderId == item.BlockedId && m.ReceiverId == item.BlockerId)).Count()</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action btn-view btn btn-sm btn-outline-primary">Chi tiết</button>
                                        <button class="btn-action btn-block btn btn-sm btn-outline-warning">Chặn</button>
                                        <button class="btn-action btn-remove btn btn-sm btn-outline-danger">Xóa</button>
                                    </div>
                                </td>
                            </tr>
                        } *@
                        
                    </tbody>
                </table>
            </div>

            <div class="pagination">
                <button disabled>← Trước</button>
                <button class="active">1</button>
                <button>2</button>
                <button>3</button>
                <button>4</button>
                <button>5</button>
                <button>Sau →</button>
            </div>
        </div>
    </div>

    <!-- FRIEND DETAIL MODAL -->
    <div class="modal fade" id="friendDetailModal" tabindex="-1" aria-labelledby="friendDetailLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 id="friendDetailLabel" class="modal-title">Chi tiết kết nối</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-3">Người dùng 1</dt>
                        <dd class="col-sm-9" id="detail-user1"></dd>

                        <dt class="col-sm-3">Người dùng 2</dt>
                        <dd class="col-sm-9" id="detail-user2"></dd>

                        <dt class="col-sm-3">Trạng thái</dt>
                        <dd class="col-sm-9" id="detail-status"></dd>

                        <dt class="col-sm-3">Ngày</dt>
                        <dd class="col-sm-9" id="detail-date"></dd>

                        <dt class="col-sm-3">Số tin nhắn</dt>
                        <dd class="col-sm-9" id="detail-messages"></dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>

    <!-- CONFIRM ACTION MODAL (BLOCK / REMOVE) -->
    <div class="modal fade" id="confirmFriendModal" tabindex="-1" aria-labelledby="confirmFriendLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 id="confirmFriendLabel" class="modal-title">Xác nhận hành động</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <p id="confirm-friend-message"></p>
                </div>
                <div class="modal-footer">
                    <button id="confirm-cancel" type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button id="confirm-doit" type="button" class="btn btn-primary">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@* anti-forgery token for AJAX *@
@Html.AntiForgeryToken()

<script>
    let friendlists = '@friendListJson';
    let friendinvitations = '@friendInvitationJson';
    let messages = '@messagesJson';
    friendlists = friendlists.replace(/&quot;/g, '"');
    friendinvitations = friendinvitations.replace(/&quot;/g, '"');
    messages = messages.replace(/&quot;/g, '"');

    // endpoints used by friendlist.js (server actions to implement)
    const blockFriendUrl = '@Url.Action("BlockFriend", "Admin")';
    const removeFriendUrl = '@Url.Action("RemoveFriend", "Admin")';
</script>
<script src="~/js/friendlist.js"></script>
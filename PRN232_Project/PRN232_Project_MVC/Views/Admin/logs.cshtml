@model IEnumerable<PRN232_Project_MVC.Models.Dto.LogDto>
@{
    var logJson = System.Text.Json.JsonSerializer.Serialize(Model);
    var log5 = Model.SkipLast(Model.Count() - 5);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Nhật Ký Hoạt Động - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PRN232_Project_MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/logs.css"/>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>
                <span class="header-icon">📊</span>
                Quản Lý Nhật Ký Hoạt Động
            </h1>
            <nav class="nav-menu">
                <a href="/Admin/Users" class="nav-btn">👥 Người Dùng</a>
                <a href="/Admin/Friendlist" class="nav-btn">🤝 Bạn Bè</a>
                <a href="/Admin/Accusations" class="nav-btn">⚠️ Tố Cáo</a>
                <a href="/Admin/Logs" class="nav-btn active">📊 Nhật Ký</a>
            </nav>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Hoạt Động Hôm Nay</h3>
                <div class="stat-value">@Model.Where(l => l.TimeStamp > DateTime.Now).Count()</div>
                <div class="stat-change positive">
                    ↑ +12.3% so với hôm qua
                </div>
            </div>
            <div class="stat-card">
                <h3>Người Lạ</h3>
                <div class="stat-value">@Model.Where(l => l.Action.ToLower() == "stranger").Count()</div>
                <div class="stat-change positive">
                    ↑ +8.7% so với hôm qua
                </div>
            </div>
            <div class="stat-card">
                <h3>Bạn Bè</h3>
                <div class="stat-value">@Model.Where(l => l.Action.ToLower() == "friend").Count()</div>
                <div class="stat-change positive">
                    ↑ +8.7% so với hôm qua
                </div>
            </div>
            <div class="stat-card">
                <h3>Đăng Nhập</h3>
                <div class="stat-value">@Model.Where(l => l.Action.ToLower() == "login").Count()</div>
                <div class="stat-change positive">
                    ↑ +15.2% so với hôm qua
                </div>
            </div>
            <div class="stat-card">
                <h3>Đăng Xuất</h3>
                <div class="stat-value">@Model.Where(l => l.Action.ToLower() == "logout").Count()</div>
                <div class="stat-change negative">
                    ↓ -3.4% so với hôm qua
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Nhật Ký Hoạt Động Chi Tiết</h2>
            </div>

            <div class="search-filter-bar">
                <div class="search-box">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Tìm kiếm theo người dùng, IP, hoạt động...">
                </div>
                <select class="filter-select">
                    <option value="">Tất cả loại hoạt động</option>
                    <option value="stranger">Người lạ</option>
                    <option value="friend">Bạn bè</option>
                    <option value="login">Đăng nhập</option>
                    <option value="logout">Đăng xuất</option>
                </select>
                <select class="filter-select">
                    <option value="">Thời gian</option>
                    <option value="today">Hôm nay</option>
                    <option value="yesterday">Hôm qua</option>
                    <option value="week">7 ngày qua</option>
                    <option value="month">30 ngày qua</option>
                </select>
                <button id="excelBtn" class="btn-primary">
                    📊 Xuất Báo Cáo
                </button>
            </div>

            <div class="timeline-container">
                <div class="timeline-line"></div>

                @foreach (var item in log5)
                {
                    <div class="log-item message">
                        <div class="log-header">
                            <div class="log-user">
                                <div class="user-avatar">NT</div>
                                <div class="user-info">
                                    <h4>@item.User.Username</h4>
                                    <p>@item.User.Email</p>
                                </div>
                            </div>
                            <div class="log-time">5 phút trước</div>
                        </div>
                        <div class="log-content">
                            <div class="log-description">
                                <span class="badge @item.Action.ToLower()">@item.Action</span>
                                @item.Description
                            </div>
                            <div class="log-meta">
                                <div class="meta-item">
                                    <span class="meta-icon">🕐</span>
                                    <span>@item.TimeStamp</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="load-more">
                <button id="loadMoreBtn" class="btn-load-more">Tải thêm hoạt động</button>
            </div>
        </div>
    </div>
</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    let logs = '@logJson';
    logs = logs.replace(/&quot;/g, '"');
</script>
<script src="~/js/logs.js"></script>
@model IEnumerable<PRN232_Project_MVC.Models.Accusation>

@{
    var accusationJson = System.Text.Json.JsonSerializer.Serialize(Model);
    var accusation3 = Model.SkipLast(Model.Count() - 5);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Tố Cáo - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PRN232_Project_MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/accusations.css" />
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>
                <span class="header-icon">⚠️</span>
                Quản Lý Tố Cáo
            </h1>
            <nav class="nav-menu">
                <a href="/Admin/Users" class="nav-btn">👥 Người Dùng</a>
                <a href="/Admin/Friendlist" class="nav-btn">🤝 Bạn Bè</a>
                <a href="/Admin/Accusations" class="nav-btn active">⚠️ Tố Cáo</a>
                <a href="/Admin/Logs" class="nav-btn">📊 Nhật Ký</a>
            </nav>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Tổng Tố Cáo</h3>
                <div class="stat-value">@Model.Where(a => a.CreatedAt > DateTime.Now.AddMonths(-1)).Count()</div>
                <div class="stat-change negative">
                    ↑ +23.5% so với tháng trước
                </div>
            </div>
            <div class="stat-card">
                <h3>Đang Chờ Xử Lý</h3>
                <div class="stat-value">@Model.Where(a => a.CreatedAt > DateTime.Now.AddMonths(-1) && a.Status == "Pending").Count()</div>
                <div class="stat-change negative">
                    ↑ +15.7% so với tháng trước
                </div>
            </div>
            <div class="stat-card">
                <h3>Đang Xem Xét</h3>
                <div class="stat-value">@Model.Where(a => a.CreatedAt > DateTime.Now.AddMonths(-1) && a.Status == "Reviewing").Count()</div>
                <div class="stat-change positive">
                    ↓ -8.2% so với tháng trước
                </div>
            </div>
            <div class="stat-card">
                <h3>Đã Giải Quyết</h3>
                <div class="stat-value">@Model.Where(a => a.CreatedAt > DateTime.Now.AddMonths(-1) && a.Status == "Resolved").Count()</div>
                <div class="stat-change positive">
                    ↑ +34.1% so với tháng trước
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Danh Sách Tố Cáo</h2>
            </div>

            <div class="search-filter-bar">
                <div class="search-box">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Tìm kiếm tố cáo...">
                </div>
                <select class="filter-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="pending">Đang chờ</option>
                    <option value="reviewed">Đang xem xét</option>
                    <option value="resolved">Đã giải quyết</option>
                </select>
                <select class="filter-select">
                    <option value="">Mức độ ưu tiên</option>
                    <option value="high">Cao</option>
                    <option value="medium">Trung bình</option>
                    <option value="low">Thấp</option>
                </select>
                <select class="filter-select">
                    <option value="">Sắp xếp theo</option>
                    <option value="newest">Mới nhất</option>
                    <option value="oldest">Cũ nhất</option>
                    <option value="priority">Mức độ ưu tiên</option>
                </select>
                <button id="excelBtn" class="btn-primary">
                    📊 Xuất Báo Cáo
                </button>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Người Tố Cáo</th>
                            <th>Người Bị Tố Cáo</th>
                            <th>Lý Do</th>
                            <th>Trạng Thái</th>
                            <th>Ngày Tạo</th>
                            <th>Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var accusation in accusation3)
                        {
                            <tr data-id="@accusation.AccusationId">
                                <td><strong>#@accusation.AccusationId</strong></td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">NT</div>
                                        <div class="user-info">
                                            <h4>@accusation.Reported.Username</h4>
                                            <p>@accusation.Reported.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar accused">HQ</div>
                                        <div class="user-info">
                                            <h4>@accusation.Accused.Username</h4>
                                            <p>@accusation.Accused.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="reason-cell">
                                    <div class="priority-badge @accusation.Category.ToLower()">@accusation.Category</div>
                                    <div class="reason-text">@accusation.Descriptions</div>
                                </td>
                                <td><span class="badge @accusation.Status.ToLower()">@accusation.Status</span></td>
                                <td>@accusation.CreatedAt</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action btn-review btn btn-sm btn-outline-primary">Xem xét</button>
                                        <button class="btn-action btn-resolve btn btn-sm btn-outline-success">Giải quyết</button>
                                        <button class="btn-action btn-reject btn btn-sm btn-outline-danger">Từ chối</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pagination">
                <button disabled>← Trước</button>
                <button class="active">1</button>
                <button>2</button>
                <button>3</button>
                <button>4</button>
                <button>5</button>
                <button>Sau →</button>
            </div>
        </div>
    </div>

    <!-- DETAIL MODAL -->
    <div class="modal fade" id="accusationDetailModal" tabindex="-1" aria-labelledby="accusationDetailLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 id="accusationDetailLabel" class="modal-title">Chi tiết tố cáo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-3">ID</dt>
                        <dd class="col-sm-9" id="detail-id"></dd>

                        <dt class="col-sm-3">Người tố</dt>
                        <dd class="col-sm-9" id="detail-reported"></dd>

                        <dt class="col-sm-3">Người bị tố</dt>
                        <dd class="col-sm-9" id="detail-accused"></dd>

                        <dt class="col-sm-3">Lý do</dt>
                        <dd class="col-sm-9" id="detail-category"></dd>

                        <dt class="col-sm-3">Mô tả</dt>
                        <dd class="col-sm-9" id="detail-descriptions"></dd>

                        <dt class="col-sm-3">Trạng thái</dt>
                        <dd class="col-sm-9" id="detail-status"></dd>

                        <dt class="col-sm-3">Ngày tạo</dt>
                        <dd class="col-sm-9" id="detail-createdat"></dd>

                        <dt class="col-sm-3">Ghi chú xử lý</dt>
                        <dd class="col-sm-9" id="detail-resolution"></dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>

    <!-- CONFIRM ACTION MODAL -->
    <div class="modal fade" id="confirmActionModal" tabindex="-1" aria-labelledby="confirmActionLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 id="confirmActionLabel" class="modal-title">Xác nhận hành động</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <p id="confirm-message"></p>
                    <div id="optional-note-group" style="display:none;">
                        <label for="resolution-note" class="form-label">Ghi chú (tuỳ chọn)</label>
                        <textarea id="resolution-note" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button id="confirm-cancel" type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button id="confirm-doit" type="button" class="btn btn-primary">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    let accusations = '@accusationJson';
    accusations = accusations.replace(/&quot;/g, '"');
</script>
<script src="~/js/accusation.js"></script>